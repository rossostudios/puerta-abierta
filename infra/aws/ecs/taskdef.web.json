{
  "family": "casaora-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX",
    "cpuArchitecture": "ARM64"
  },
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::341112583495:role/casaora-web-task-execution-role",
  "taskRoleArn": "arn:aws:iam::341112583495:role/casaora-web-task-role",
  "containerDefinitions": [
    {
      "name": "casaora-web",
      "image": "REPLACE_ME_IMAGE_URI",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "hostPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3001" },
        { "name": "HOSTNAME", "value": "0.0.0.0" },
        { "name": "NEXT_PUBLIC_API_BASE_URL", "value": "https://api.casaora.co/v1" },
        { "name": "NEXT_PUBLIC_SITE_URL", "value": "https://casaora.co" },
        { "name": "NEXT_PUBLIC_ADMIN_URL", "value": "https://app.casaora.co" },
        { "name": "NEXT_PUBLIC_CLERK_DOMAIN", "value": "clerk.casaora.co" },
        { "name": "NEXT_PUBLIC_CLERK_JS_URL", "value": "https://clerk.casaora.co/npm/@clerk/clerk-js@5/dist/clerk.browser.js" }
      ],
      "secrets": [
        { "name": "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY", "valueFrom": "REPLACE_ME_CLERK_PUBLISHABLE_SECRET_ARN" },
        { "name": "CLERK_SECRET_KEY", "valueFrom": "REPLACE_ME_CLERK_SECRET_ARN" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"fetch('http://localhost:3001/').then(r=>r.ok?process.exit(0):process.exit(1)).catch(()=>process.exit(1))\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/casaora-web",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
