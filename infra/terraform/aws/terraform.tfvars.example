aws_region              = "us-east-1"
aws_profile             = "default"
name_prefix             = "casaora-prod"
alb_certificate_arn     = "arn:aws:acm:us-east-1:341112583495:certificate/REPLACE_ME"
admin_alb_certificate_arn = "arn:aws:acm:us-east-1:341112583495:certificate/REPLACE_ME"
web_alb_certificate_arn = "arn:aws:acm:us-east-1:341112583495:certificate/REPLACE_ME"

# Set to false only if you haven't added app.casaora.co routing yet.
enable_admin_alb_rule = true
admin_hostnames       = ["app.casaora.co"]

# Production baseline (public web is live on AWS ECS + ALB).
enable_web_alb_rule = true
web_hostnames       = ["casaora.co", "www.casaora.co"]

# Production baseline (public media bucket is managed/imported).
enable_storage_buckets          = true
public_media_bucket_name        = "casaora-prod-public-media-341112583495"
create_private_documents_bucket = false
private_documents_bucket_name   = "casaora-prod-private-documents-341112583495"

# Production baseline (Railway schedulers replaced by EventBridge + ECS RunTask).
enable_scheduler_jobs = true
# Leave true to actually run schedules; set false for codification-only.
enable_scheduler_rules = true
scheduler_api_base_url = "https://api.casaora.co"
scheduler_internal_api_key_secret_name = "casaora/backend/INTERNAL_API_KEY"
